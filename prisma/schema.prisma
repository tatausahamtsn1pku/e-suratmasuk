generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VALIDATOR_KHUSUS
  VALIDATOR_UMUM
  KATU
  APPROVER
  STAFF
}

model User {
  id             String   @id @default(uuid())
  username       String   @unique
  password       String
  role           Role
  jabatan        String?
  waNumber       String?
  surats         Surat[]  @relation("handler")
  approvedSurats Surat[]  @relation("approver")
}

model Surat {
  id              String   @id @default(uuid())
  trackingId      String   @unique
  namaPengirim    String
  emailPengirim   String
  waPengirim      String
  instansi        String
  fileUrl         String
  nomorSurat      String?
  tglSurat        String?
  isiDisposisi    String?
  status          String   @default("PENDING_VALIDATION") 
  isNeedReplyFile Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt 
  officialEntry   DateTime 

  penerusId       String?
  handler         User?    @relation("handler", fields: [penerusId], references: [id])
  
  approverId      String?
  approver        User?    @relation("approver", fields: [approverId], references: [id])
  
  // Kolom baru untuk birokrasi KATU & Staff
  catatanKATU     String?
  ttdKATU         String?
  catatanStaff    String?
  ttdStaff        String?
  catatanApprover String?
  ttdApprover     String?
  fileReplyUrl    String?
  fileReplyName   String?
}